                    }
                ],
                [
                    {
                        "node": "Log - Sin WhatsApp",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Enviar WhatsApp (Evolution API)": {
            "main": [
                [
                    {
                        "node": "Enviado OK?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Enviado OK?": {
            "main": [
                [
                    {
                        "node": "Log - Éxito",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Log - Error WA",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "active": true,
    "settings": {
        "executionOrder": "v1",
        "timezone": "America/Mexico_City"
    },
    "versionId": "2",
    "meta": {
        "instanceId": "yalopido-instance"
    }
}